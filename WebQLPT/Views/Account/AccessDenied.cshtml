@{
    ViewData["Title"] = "Truy cập bị từ chối";
}

<div class="page-header">
    <h1>🚫 Truy Cập Bị Từ Chối</h1>
    <p>Bạn không có quyền truy cập trang này</p>
</div>

<div class="row">
    <div class="col-md-8 offset-md-2">
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
            <div class="d-flex align-items-center">
                <i class="bi bi-exclamation-triangle me-3" style="font-size: 2rem;"></i>
                <div>
                    <h4 class="alert-heading">Không Có Quyền Truy Cập</h4>
                    <p class="mb-0">
                        Tài khoản của bạn không có quyền truy cập vào trang này.
                        Vui lòng liên hệ với quản trị viên nếu bạn cho rằng đây là lỗi.
                    </p>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-body text-center py-5">
                <p class="text-muted mb-4">Bạn có thể quay lại trang chính hoặc chọn một mục từ menu bên trái</p>
                <a href="@Url.Action("Index", "Home")" class="btn btn-primary">
                    <i class="bi bi-house"></i> Quay Lại Trang Chính
                </a>
                <a href="javascript:history.back()" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Quay Lại
                </a>
            </div>
        </div>

        <div class="mt-4">
            <h5>Quyền Truy Cập Theo Vai Trò:</h5>
            <ul class="list-group">
                <li class="list-group-item">
                    <strong>👨‍💼 Admin:</strong> Có quyền truy cập tất cả các tính năng
                </li>
                <li class="list-group-item">
                    <strong>🏠 Chủ Trọ (ChuTro):</strong> Quản lý phòng trọ, khách thuê, đăng tin
                </li>
                <li class="list-group-item">
                    <strong>👤 Khách Thuê (KhachThue):</strong> Xem phòng đã thuê, đăng tin
                </li>
            </ul>
        </div>
    </div>
</div>

<style>
    .page-header {
        margin-bottom: 2rem;
        padding-bottom: 1rem;
        border-bottom: 2px solid #e2e8f0;
    }

    .page-header h1 {
        color: var(--danger);
        font-weight: 700;
        margin-bottom: 0.5rem;
    }

    .page-header p {
        color: var(--text-secondary);
    }

    .card {
        border: none;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        border-radius: 8px;
    }

    .list-group-item {
        border: 1px solid #e2e8f0;
    }

    .btn {
        margin-right: 0.5rem;
    }
</style>
