@model WebQLPT.Models.Payment
@{
    ViewData["Title"] = "Thanh toán thành công";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h3 class="card-title mb-3">Thanh toán thành công</h3>
                    <p class="mb-1">Mã giao dịch: <strong>@Model.Id</strong></p>
                    <p class="mb-1">Số tiền: <strong>@Model.Amount.ToString("N0") VND</strong></p>
                    <p class="mb-1">Trạng thái: <span class="badge bg-success">@Model.Status</span></p>
                    <p class="text-muted">Thời gian: @Model.CreatedAt</p>

                    <div class="mt-3">
                        <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Quay về trang chủ</a>
                        <a asp-controller="Payments" asp-action="Success" asp-route-id="@Model.Id" class="btn btn-link">Xem chi tiết</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
