@model WebQLPT.Controllers.PaymentsController.PaymentInputModel
@{
    ViewData["Title"] = "Thanh toán";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h4 class="card-title mb-3">Thanh toán</h4>
                    @if (ViewBag.DangTinTitle != null)
                    {
                        <p class="text-muted">Thanh toán cho: <strong>@ViewBag.DangTinTitle</strong></p>
                    }

                    <form asp-action="CheckoutPost" method="post">
                        @Html.AntiForgeryToken()
                        <input asp-for="DangTinId" type="hidden" />
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Amount" class="form-label">Số tiền (VND)</label>
                            <input asp-for="Amount" class="form-control" type="number" step="0.01" min="0" />
                            <span asp-validation-for="Amount" class="text-danger"></span>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-success">Thanh toán (mock)</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<partial name="_ValidationScriptsPartial" />
