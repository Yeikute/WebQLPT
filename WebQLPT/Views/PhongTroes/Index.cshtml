@model IEnumerable<WebQLPT.Models.PhongTro>

@{
    ViewData["Title"] = "Quản Lý Phòng Trọ";
}

<div class="page-header">
    <h1>🏠 Quản Lý Phòng Trọ</h1>
    <p>Danh sách tất cả phòng trọ trong hệ thống</p>
</div>

<div class="d-flex justify-content-between align-items-center mb-3 gap-2">
    @if (User.IsInRole("Admin") || User.IsInRole("ChuTro"))
    {
        <a asp-action="Create" class="btn-create">
            <i class="bi bi-plus-circle"></i> Thêm Phòng Mới
        </a>
    }
</div>

<div class="search-bar">
    <form method="get" asp-action="Index" class="d-flex w-100 gap-2">
        <input type="text" name="keyword" class="form-control" placeholder="🔍 Tìm kiếm theo tên phòng..." />
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-search"></i> Tìm
        </button>
    </form>
</div>

@if (Model.Any())
{
    <div class="table-container">
        <table class="table">
            <thead>
                <tr>
                    <th>Tên Phòng</th>
                    <th>Giá (VNĐ)</th>
                    <th>Trạng Thái</th>
                    <th>Mô Tả</th>
                    <th>Chủ Trọ</th>
                    <th>Hành Động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <strong>@Html.DisplayFor(modelItem => item.TenPhong)</strong>
                        </td>
                        <td>
                            <span class="badge bg-success">@item.Gia.ToString("N0")</span>
                        </td>
                        <td>
                            @{
                                var statusClass = item.TrangThai == "Trống" ? "bg-success" : item.TrangThai == "Đã cho thuê" ? "bg-warning" : "bg-danger";
                            }
                            <span class="badge @statusClass">@Html.DisplayFor(modelItem => item.TrangThai)</span>
                        </td>
                        <td>
                            @{
                                var moTa = item.MoTa ?? string.Empty;
                                if (moTa.Length > 50)
                                {
                                    <span title="@moTa">@moTa.Substring(0, 50)...</span>
                                }
                                else
                                {
                                    <span>@moTa</span>
                                }
                            }
                        </td>
                        <td>@Html.DisplayFor(modelItem => item.ChuTro.TenChuTro)</td>
                        <td>
                            <div class="btn-action">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn-detail" title="Xem chi tiết">
                                    <i class="bi bi-eye"></i> Chi tiết
                                </a>

                                @if (User.IsInRole("Admin") || User.IsInRole("ChuTro"))
                                {
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn-edit" title="Chỉnh sửa">
                                        <i class="bi bi-pencil"></i> Sửa
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn-delete" title="Xóa">
                                        <i class="bi bi-trash"></i> Xóa
                                    </a>
                                }

                                @if (User.IsInRole("KhachThue") && item.TrangThai == "Trống")
                                {
                                    <a asp-action="Rent" asp-route-id="@item.Id" class="btn btn-sm btn-success">Thuê</a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="table-container">
        <div class="empty-state">
            <div class="empty-state-icon">📭</div>
            <div class="empty-state-title">Không có phòng trọ nào</div>
            <div class="empty-state-text">Hãy thêm phòng trọ mới để bắt đầu quản lý</div>
            <a asp-action="Create" class="btn-create">
                <i class="bi bi-plus-circle"></i> Thêm Phòng Mới
            </a>
        </div>
    </div>
}
