@model IEnumerable<WebQLPT.Models.ChuTro>

@{
    ViewData["Title"] = "Quản Lý Chủ Trọ";
}

<div class="page-header">
    <h1>🏡 Quản Lý Chủ Trọ</h1>
    <p>Danh sách tất cả chủ trọ trong hệ thống</p>
</div>

<div class="d-flex justify-content-between align-items-center mb-3 gap-2">
    <a asp-action="Create" class="btn-create">
        <i class="bi bi-person-badge"></i> Thêm Chủ Trọ Mới
    </a>
</div>

<div class="search-bar">
    <form method="get" asp-action="Index" class="d-flex w-100 gap-2">
        <input type="text" name="keyword" class="form-control" placeholder="🔍 Tìm kiếm theo tên hoặc email..." />
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-search"></i> Tìm
        </button>
    </form>
</div>

@if (Model.Any())
{
    <div class="table-container">
        <table class="table">
            <thead>
                <tr>
                    <th>Tên Chủ Trọ</th>
                    <th>Số Điện Thoại</th>
                    <th>Email</th>
                    <th>Địa Chỉ</th>
                    <th>Hành Động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <strong>@Html.DisplayFor(modelItem => item.TenChuTro)</strong>
                        </td>
                        <td>
                            <a href="tel:@item.SoDienThoai">@Html.DisplayFor(modelItem => item.SoDienThoai)</a>
                        </td>
                        <td>
                            <a href="mailto:@item.Email">@Html.DisplayFor(modelItem => item.Email)</a>
                        </td>
                        <td>
                            @{
                                var diaChi = Html.DisplayFor(modelItem => item.DiaChi).ToString();
                                if (diaChi.Length > 40)
                                {
                                    <span title="@diaChi">@diaChi.Substring(0, 40)...</span>
                                }
                                else
                                {
                                    <span>@diaChi</span>
                                }
                            }
                        </td>
                        <td>
                            <div class="btn-action">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn-edit" title="Chỉnh sửa">
                                    <i class="bi bi-pencil"></i> Sửa
                                </a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn-detail" title="Xem chi tiết">
                                    <i class="bi bi-eye"></i> Chi tiết
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn-delete" title="Xóa">
                                    <i class="bi bi-trash"></i> Xóa
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="table-container">
        <div class="empty-state">
            <div class="empty-state-icon">📭</div>
            <div class="empty-state-title">Không có chủ trọ nào</div>
            <div class="empty-state-text">Hãy thêm chủ trọ mới để bắt đầu quản lý</div>
            <a asp-action="Create" class="btn-create">
                <i class="bi bi-person-badge"></i> Thêm Chủ Trọ Mới
            </a>
        </div>
    </div>
}
