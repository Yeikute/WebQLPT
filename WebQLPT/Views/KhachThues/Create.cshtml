@model WebQLPT.Models.KhachThue

@{
    ViewData["Title"] = "Thêm Khách Thuê Mới";
}

<div class="page-header">
    <h1>👥 Thêm Khách Thuê Mới</h1>
    <p>Nhập thông tin chi tiết cho khách thuê mới</p>
</div>

<div class="form-container" style="max-width: 600px;">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

        @if (ViewBag.SelectedUser != null)
        {
            <div class="mb-3">
                <label class="form-label">Người dùng</label>
                <div class="p-2 border rounded">
                    <strong>@(ViewBag.SelectedUser.FullName ?? ViewBag.SelectedUser.UserName)</strong>
                    <div class="text-muted">@ViewBag.SelectedUser.Email</div>
                </div>
            </div>
            <input type="hidden" asp-for="UserId" />
        }

        <div class="form-group">
            <label asp-for="TenKhach">
                Tên Khách Thuê
                <span class="required">*</span>
            </label>
            <input asp-for="TenKhach" class="form-control" placeholder="Ví dụ: Nguyễn Văn A" />
            <span asp-validation-for="TenKhach" class="invalid-feedback"></span>
        </div>

        <div class="form-group">
            <label asp-for="SoDienThoai">
                Số Điện Thoại
                <span class="required">*</span>
            </label>
            <input asp-for="SoDienThoai" class="form-control" type="tel" placeholder="Ví dụ: 0901234567" />
            <span asp-validation-for="SoDienThoai" class="invalid-feedback"></span>
        </div>

        <div class="form-group">
            <label asp-for="CCCD">
                CCCD / CMT
                <span class="required">*</span>
            </label>
            <input asp-for="CCCD" class="form-control" placeholder="Ví dụ: 0123456789" />
            <span asp-validation-for="CCCD" class="invalid-feedback"></span>
        </div>

        <div class="form-group">
            <label asp-for="NgayThue">
                Ngày Thuê
                <span class="required">*</span>
            </label>
            <input asp-for="NgayThue" type="date" class="form-control" />
            <span asp-validation-for="NgayThue" class="invalid-feedback"></span>
        </div>

        <div class="form-group">
            <label asp-for="PhongTroId">
                Phòng Trọ
                <span class="required">*</span>
            </label>
            <select asp-for="PhongTroId" class="form-select" asp-items="ViewBag.PhongTroId">
                <option value="">-- Chọn Phòng Trọ --</option>
            </select>
            <span asp-validation-for="PhongTroId" class="invalid-feedback"></span>
        </div>

        <div class="btn-form-group">
            <button type="submit" class="btn-submit">
                <i class="bi bi-check-circle"></i> Thêm Khách Thuê
            </button>
            <a asp-action="Index" class="btn-cancel">
                <i class="bi bi-x-circle"></i> Hủy
            </a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}