@model IEnumerable<WebQLPT.Models.KhachThue>

@{
    ViewData["Title"] = "Quản Lý Khách Thuê";
}

<div class="page-header">
    <h1>👥 Quản Lý Khách Thuê</h1>
    <p>Danh sách tất cả khách thuê trong hệ thống</p>
</div>

<div class="d-flex justify-content-between align-items-center mb-3 gap-2">
    <a asp-action="Create" class="btn-create">
        <i class="bi bi-person-plus"></i> Thêm Khách Mới
    </a>
</div>

<div class="search-bar">
    <form method="get" asp-action="Index" class="d-flex w-100 gap-2">
        <input type="text" name="keyword" class="form-control" placeholder="🔍 Tìm kiếm theo tên hoặc số điện thoại..." />
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-search"></i> Tìm
        </button>
    </form>
</div>

@if (Model.Any())
{
    <div class="table-container">
        <table class="table">
            <thead>
                <tr>
                    <th>Tên Khách</th>
                    <th>Số Điện Thoại</th>
                    <th>CCCD</th>
                    <th>Ngày Thuê</th>
                    <th>Phòng Trọ</th>
                    <th>Hành Động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <strong>@item.TenKhach</strong>
                        </td>
                        <td>
                            <a href="tel:@item.SoDienThoai">@item.SoDienThoai</a>
                        </td>
                        <td>
                            <span class="badge bg-secondary">@item.CCCD</span>
                        </td>
                        <td>
                            <span>@item.NgayThue.ToString("dd/MM/yyyy")</span>
                        </td>
                        <td>
                            <span class="badge bg-info">@item.PhongTro?.TenPhong</span>
                        </td>
                        <td>
                            <div class="btn-action">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn-edit" title="Chỉnh sửa">
                                    <i class="bi bi-pencil"></i> Sửa
                                </a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn-detail" title="Xem chi tiết">
                                    <i class="bi bi-eye"></i> Chi tiết
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn-delete" title="Xóa">
                                    <i class="bi bi-trash"></i> Xóa
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="table-container">
        <div class="empty-state">
            <div class="empty-state-icon">📭</div>
            <div class="empty-state-title">Không có khách thuê nào</div>
            <div class="empty-state-text">Hãy thêm khách thuê mới để bắt đầu quản lý</div>
            <a asp-action="Create" class="btn-create">
                <i class="bi bi-person-plus"></i> Thêm Khách Mới
            </a>
        </div>
    </div>
}
