@model IEnumerable<WebQLPT.Models.KhachThue>

@{
    ViewData["Title"] = "Index";
}

<h1>Danh sách khách thuê</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<form method="get" asp-action="Index" class="mb-3 d-flex">
    <input type="text" name="keyword" class="form-control me-2" placeholder="Tìm khách..." />
    <button type="submit" class="btn btn-primary">Tìm</button>
</form>
<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.TenKhach)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.SoDienThoai)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CCCD)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.NgayThue)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.PhongTro)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
                <td>@item.TenKhach</td>
                <td>@item.SoDienThoai</td>
                <td>@item.CCCD</td>
                <td>@item.NgayThue.ToString("dd/MM/yyyy")</td>
                <td>@item.PhongTro?.TenPhong</td>
                <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
