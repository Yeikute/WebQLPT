@{
    ViewData["Title"] = "Dashboard";
}

<style>
    .dashboard-header {
        margin-bottom: 2.5rem;
        padding-bottom: 2rem;
        border-bottom: 2px solid rgba(226, 232, 240, 0.5);
        animation: slideInLeft 0.6s ease-out;
    }

    .dashboard-header h1 {
        font-size: 2.5rem;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 0.5rem;
        letter-spacing: -0.5px;
        background: linear-gradient(135deg, #3b82f6 0%, #8b5cf6 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .dashboard-header p {
        color: #64748b;
        font-size: 1.05rem;
        margin-bottom: 0;
        font-weight: 500;
    }

    /* ===== STAT CARDS ===== */
    .stat-card {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(226, 232, 240, 0.6);
        border-radius: 1.25rem;
        padding: 2rem;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
        overflow: hidden;
        animation: fadeInUp 0.6s ease-out;
    }

    .stat-card::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -50%;
        width: 200px;
        height: 200px;
        border-radius: 50%;
        opacity: 0;
        transition: all 0.6s ease;
    }

    .stat-card.primary::before {
        background: radial-gradient(circle, rgba(59, 130, 246, 0.15) 0%, transparent 70%);
    }

    .stat-card.success::before {
        background: radial-gradient(circle, rgba(34, 197, 94, 0.15) 0%, transparent 70%);
    }

    .stat-card.warning::before {
        background: radial-gradient(circle, rgba(245, 158, 11, 0.15) 0%, transparent 70%);
    }

    .stat-card.danger::before {
        background: radial-gradient(circle, rgba(239, 68, 68, 0.15) 0%, transparent 70%);
    }

    .stat-card:hover {
        border-color: rgba(59, 130, 246, 0.3);
        box-shadow: 0 20px 60px rgba(59, 130, 246, 0.12), 0 0 40px rgba(59, 130, 246, 0.05);
        transform: translateY(-8px);
        background: rgba(255, 255, 255, 0.98);
    }

    .stat-card:hover::before {
        opacity: 1;
        top: -25%;
        right: -25%;
    }

    .stat-card:nth-child(2):hover {
        border-color: rgba(34, 197, 94, 0.3);
        box-shadow: 0 20px 60px rgba(34, 197, 94, 0.12), 0 0 40px rgba(34, 197, 94, 0.05);
    }

    .stat-card:nth-child(3):hover {
        border-color: rgba(245, 158, 11, 0.3);
        box-shadow: 0 20px 60px rgba(245, 158, 11, 0.12), 0 0 40px rgba(245, 158, 11, 0.05);
    }

    .stat-card:nth-child(4):hover {
        border-color: rgba(239, 68, 68, 0.3);
        box-shadow: 0 20px 60px rgba(239, 68, 68, 0.12), 0 0 40px rgba(239, 68, 68, 0.05);
    }

    .stat-card > * {
        position: relative;
        z-index: 1;
    }

    .stat-icon {
        width: 70px;
        height: 70px;
        border-radius: 1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.75rem;
        margin-bottom: 1.5rem;
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.8);
    }

    .stat-icon.primary {
        background: linear-gradient(135deg, rgba(59, 130, 246, 0.15) 0%, rgba(59, 130, 246, 0.05) 100%);
        color: #1e40af;
    }

    .stat-icon.success {
        background: linear-gradient(135deg, rgba(34, 197, 94, 0.15) 0%, rgba(34, 197, 94, 0.05) 100%);
        color: #15803d;
    }

    .stat-icon.warning {
        background: linear-gradient(135deg, rgba(245, 158, 11, 0.15) 0%, rgba(245, 158, 11, 0.05) 100%);
        color: #92400e;
    }

    .stat-icon.danger {
        background: linear-gradient(135deg, rgba(239, 68, 68, 0.15) 0%, rgba(239, 68, 68, 0.05) 100%);
        color: #7f1d1d;
    }

    .stat-value {
        font-size: 3rem;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 0.75rem;
        letter-spacing: -1px;
    }

    .stat-label {
        font-size: 0.9rem;
        color: #64748b;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.8px;
    }

    /* ===== CHART CARDS ===== */
    .chart-card {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(226, 232, 240, 0.6);
        border-radius: 1.25rem;
        padding: 2rem;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.05);
        animation: fadeInUp 0.6s ease-out;
        animation-delay: 0.1s;
    }

    .chart-card h5 {
        font-weight: 700;
        color: #0f172a;
        margin-bottom: 1.5rem;
        font-size: 1.2rem;
        letter-spacing: -0.3px;
    }

    .chart-card:hover {
        border-color: rgba(59, 130, 246, 0.3);
        box-shadow: 0 20px 60px rgba(59, 130, 246, 0.1), 0 0 40px rgba(59, 130, 246, 0.05);
        transform: translateY(-4px);
        transition: all 0.4s ease;
    }

    /* ===== REPORT ITEMS ===== */
    .report-item {
        padding: 1.25rem;
        border-radius: 1rem;
        transition: all 0.3s ease;
        background: linear-gradient(135deg, rgba(59, 130, 246, 0.03) 0%, rgba(139, 92, 246, 0.03) 100%);
        border: 1px solid rgba(226, 232, 240, 0.4);
        margin-bottom: 1rem;
    }

    .report-item:hover {
        background: linear-gradient(135deg, rgba(59, 130, 246, 0.08) 0%, rgba(139, 92, 246, 0.08) 100%);
        border-color: rgba(59, 130, 246, 0.3);
        transform: translateX(6px);
    }

    .report-item:last-child {
        margin-bottom: 0;
    }

    .report-item .report-title {
        font-weight: 600;
        color: #0f172a;
        margin-bottom: 0.5rem;
        font-size: 1rem;
    }

    .report-item .report-subtitle {
        font-size: 0.85rem;
        color: #94a3b8;
    }

    .report-item .report-value {
        font-weight: 700;
        font-size: 1.5rem;
        color: #3b82f6;
    }

    /* ===== NOTIFICATIONS ===== */
    .notification-item {
        padding: 1.25rem;
        border-bottom: 1px solid rgba(226, 232, 240, 0.4);
        transition: all 0.3s ease;
        border-radius: 0.75rem;
        margin-bottom: 0.75rem;
    }

    .notification-item:hover {
        background: linear-gradient(135deg, rgba(59, 130, 246, 0.05) 0%, rgba(139, 92, 246, 0.05) 100%);
        border-radius: 1rem;
    }

    .notification-item:last-child {
        border-bottom: none;
        margin-bottom: 0;
    }

    .notification-badge {
        display: inline-block;
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background-color: #3b82f6;
        margin-right: 1rem;
        animation: pulse 2s infinite;
    }

    .notification-item-title {
        font-weight: 600;
        color: #0f172a;
        margin-bottom: 0.25rem;
    }

    .notification-item-subtitle {
        font-size: 0.85rem;
        color: #94a3b8;
    }
</style>

<div class="dashboard-header">
    <h1>📊 Bảng Điều Khiển</h1>
    <p>Tổng quan hệ thống quản lý phòng trọ của bạn</p>
</div>

<!-- Stats Row -->
<div class="row g-4 mb-4">
    <!-- Khách thuê card -->
    <div class="col-sm-6 col-lg-3">
        <div class="stat-card primary">
            <div class="stat-icon primary">
                <i class="bi bi-people-fill"></i>
            </div>
            <div class="stat-value">@ViewBag.SoKhach</div>
            <div class="stat-label">Khách thuê</div>
        </div>
    </div>

    <!-- Phòng trọ card -->
    <div class="col-sm-6 col-lg-3">
        <div class="stat-card success">
            <div class="stat-icon success">
                <i class="bi bi-building"></i>
            </div>
            <div class="stat-value">@ViewBag.SoPhong</div>
            <div class="stat-label">Phòng trọ</div>
        </div>
    </div>

    <!-- Hóa đơn card -->
    <div class="col-sm-6 col-lg-3">
        <div class="stat-card warning">
            <div class="stat-icon warning">
                <i class="bi bi-receipt"></i>
            </div>
            <div class="stat-value">0</div>
            <div class="stat-label">Hóa đơn</div>
        </div>
    </div>

    <!-- Đánh giá card -->
    <div class="col-sm-6 col-lg-3">
        <div class="stat-card danger">
            <div class="stat-icon danger">
                <i class="bi bi-chat-left-text"></i>
            </div>
            <div class="stat-value">0</div>
            <div class="stat-label">Đánh giá</div>
        </div>
    </div>
</div>

<!-- Report and Notifications Row -->
<div class="row g-4">
    <!-- Báo cáo gần đây -->
    <div class="col-lg-8">
        <div class="chart-card">
            <h5 class="mb-3">
                <i class="bi bi-graph-up-arrow me-2"></i>Báo Cáo Gần Đây
            </h5>
            <div class="d-flex flex-column gap-0">
                <div class="report-item">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div class="report-title">💰 Tổng doanh thu tháng này</div>
                            <div class="report-subtitle">Cập nhật lần cuối vừa rồi</div>
                        </div>
                        <div class="report-value">0 VNĐ</div>
                    </div>
                </div>
                <div class="report-item">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div class="report-title">🏠 Phòng đang cho thuê</div>
                            <div class="report-subtitle">Cập nhật lần cuối vừa rồi</div>
                        </div>
                        <div class="report-value" style="color: #22c55e;">@ViewBag.SoPhong</div>
                    </div>
                </div>
                <div class="report-item">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div class="report-title">👥 Khách mới</div>
                            <div class="report-subtitle">Cập nhật lần cuối vừa rồi</div>
                        </div>
                        <div class="report-value" style="color: #f59e0b;">@ViewBag.SoKhach</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Thông báo -->
    <div class="col-lg-4">
        <div class="chart-card">
            <h5 class="mb-3">
                <i class="bi bi-bell-fill me-2"></i>Thông Báo
            </h5>
            <div style="max-height: 350px; overflow-y: auto;">
                <div class="notification-item">
                    <div class="d-flex align-items-start">
                        <span class="notification-badge"></span>
                        <div style="flex: 1;">
                            <div class="notification-item-title">Không có thông báo mới</div>
                            <div class="notification-item-subtitle">Tất cả hoạt động đều được cập nhật</div>
                        </div>
                    </div>
                </div>
                <div class="notification-item">
                    <div class="d-flex align-items-start">
                        <span class="notification-badge" style="background-color: #22c55e;"></span>
                        <div style="flex: 1;">
                            <div class="notification-item-title">✅ Hệ thống hoạt động bình thường</div>
                            <div class="notification-item-subtitle">Tất cả dịch vụ đang hoạt động tốt</div>
                        </div>
                    </div>
                </div>
                <div class="notification-item">
                    <div class="d-flex align-items-start">
                        <span class="notification-badge" style="background-color: #8b5cf6;"></span>
                        <div style="flex: 1;">
                            <div class="notification-item-title">🎉 Cập nhật hệ thống thành công</div>
                            <div class="notification-item-subtitle">Phiên bản mới đã được triển khai</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
