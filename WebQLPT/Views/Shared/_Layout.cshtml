<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WebQLPT</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body>
    <div class="app-root d-flex">
        <aside class="sidebar bg-white border-end">
            <div class="sidebar-header p-3 d-flex align-items-center">
                <a class="navbar-brand mb-0" asp-area="" asp-controller="Home" asp-action="Index">WebQLPT</a>
            </div>
            <nav class="nav flex-column p-2">
                <a class="nav-link d-flex align-items-center" asp-controller="Home" asp-action="Index"><i class="bi bi-speedometer2 me-2"></i>Dashboard</a>
                <a class="nav-link d-flex align-items-center" href="#"><i class="bi bi-person-fill me-2"></i>Khách thuê</a>
                <a class="nav-link d-flex align-items-center" href="#"><i class="bi bi-building me-2"></i>Phòng trọ</a>
                <a class="nav-link d-flex align-items-center" href="#"><i class="bi bi-house-fill me-2"></i>Chủ trọ</a>
                <a class="nav-link d-flex align-items-center" href="#"><i class="bi bi-pencil-square me-2"></i>Đăng tin</a>
                <a class="nav-link d-flex align-items-center" href="#"><i class="bi bi-chat-left-text me-2"></i>Đánh giá</a>
                <a class="nav-link d-flex align-items-center" href="#"><i class="bi bi-receipt me-2"></i>Hóa đơn</a>
                <a class="nav-link d-flex align-items-center" href="#"><i class="bi bi-envelope me-2"></i>Liên hệ</a>
            </nav>
        </aside>
        <div class="content flex-fill d-flex flex-column">
            <header class="topbar bg-white border-bottom">
                <div class="container-fluid d-flex align-items-center justify-content-between">
                    <form class="d-flex w-50" role="search">
                        <input class="form-control form-control-sm me-2" type="search" placeholder="Tìm kiếm..." aria-label="Search">
                    </form>
                    <div class="d-flex align-items-center">
                        <div class="me-3 text-muted small">Xin chào, Admin</div>
                        <div>
                            <button class="btn btn-outline-secondary btn-sm"><i class="bi bi-person-circle"></i></button>
                        </div>
                    </div>
                </div>
            </header>

            <main role="main" class="p-4">
                @RenderBody()
            </main>
            <footer class="border-top footer text-muted mt-auto">
                <div class="container">
                    &copy; 2026 - WebQLPT
                </div>
            </footer>
        </div>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - WebQLPT - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
